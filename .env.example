# Origin of the companion NestJS backend (no trailing slash, no /quran suffix).
# Must be the deployed API host, not a *.vercel.app preview URL in production.
# Example: https://quran-chrome-extension-api.vercel.app
VITE_API_URL=http://localhost:3000

# Shared secret that the backend expects on every request (extension_secret header).
VITE_EXTENSION_SECRET=

# No QF OAuth2 credentials live in the extension.
# The backend owns QF_USER_CLIENT_ID, QF_USER_CLIENT_SECRET, etc.
# See the backend .env.example for the full OAuth + Upstash variable list.
